{
  "manifest_version": 3,
  "name": "SheynEQ",
  "short_name": "SheynEQ",
  "version": "1.0.1",
  "description": "Browser audio EQ and bass enhancer for supported music sites.",
  "action": {
    "default_title": "SheynEQ",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "tabCapture", "offscreen"],
  "host_permissions": [
    "*://*.music.yandex.ru/*",
    "*://music.yandex.ru/*",
    "*://*.vk.com/*",
    "*://vk.com/*",
    "*://*.youtube.com/*",
    "*://youtube.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none';"
  },
  "offline_enabled": true
}
